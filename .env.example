NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

RESEND_API_KEY=
ADMIN_NOTIFICATION_EMAIL=

# Optional local smoke-test token for admin APIs. Do not expose publicly.
ADMIN_PREVIEW_TOKEN=
RATE_LIMIT_HASH_SECRET=

# Local development admin bootstrap only. Store real values in ignored .env.
# Never expose these through NEXT_PUBLIC_ variables or commit real passwords.
ADMIN_DEV_EMAIL=
ADMIN_DEV_PASSWORD=

# RateHawk / ETG hotel API. Server-only: never expose through NEXT_PUBLIC_*.
RATEHAWK_ENV=test
RATEHAWK_SANDBOX_BASE_URL=https://api-sandbox.worldota.net
RATEHAWK_SANDBOX_KEY_ID=
RATEHAWK_SANDBOX_API_KEY=
RATEHAWK_TEST_BASE_URL=https://api.worldota.net
RATEHAWK_TEST_KEY_ID=
RATEHAWK_TEST_API_KEY=
RATEHAWK_PROD_BASE_URL=https://api.worldota.net
RATEHAWK_PROD_KEY_ID=
RATEHAWK_PROD_API_KEY=
RATEHAWK_WEBHOOK_SECRET=
RATEHAWK_CONTRACT_NUMBER=
RATEHAWK_STATIC_LANGUAGE=en
RATEHAWK_STATIC_INVENTORY=preferable

# Stripe payment. STRIPE_SECRET_KEY is server-only — never expose through NEXT_PUBLIC_*.
# Use test-mode keys locally (sk_test_... / pk_test_...).
# For local webhook forwarding: stripe listen --forward-to localhost:3000/api/webhook/stripe
# Use the whsec_... from stripe listen output as STRIPE_WEBHOOK_SECRET locally.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_PATH=/api/webhook/stripe
STRIPE_DEFAULT_CURRENCY=usd
